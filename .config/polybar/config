[colors]
background = #2e3440
foreground = #e5e9f0
foreground-focus = #88c0d0
foreground-not-focus = #4c566a
alert = #bf616a

[bar/topbar]
monitor = ${env:MONITOR:HDMI-0}
width = 100%
height = 25
offset-x = 0
offset-y = 0
radius = 0
fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 0

border-size = 0

padding-left = 5
padding-right = 5

module-margin-left = 2
module-margin-right = 2

font-0 = Monaco For Powerline:size=10;2
font-1 = Material Icons:style=Regular:size=10;2
font-2 = FontAwesome5Free:style=Solid:size=10;2
font-3 = FontAwesome5Free:style=Regular:size=10;2

modules-left = alsa
modules-center = i3
modules-right = eth date

tray-position = none

[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /

label-mounted = %{F#0a81f5}%mountpoint%%{F-}: %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.foreground-alt}

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = false
enable-scroll = false
wrapping-scroll = false

; Only show workspaces on the same output as the bar
pin-workspaces = true

label-mode-padding = 2
label-mode-foreground = ${colors.foreground}
label-mode-background = ${colors.background}

; focused = Active workspace on focused monitor
label-focused = "Ó†∑"
label-focused-background = ${colors.background}
label-focused-foreground = ${colors.foreground-focus}
label-focused-underline= ${colors.background}
label-focused-padding = 2

; unfocused = Inactive workspace on any monitor
label-unfocused = "Ó†∂"
label-unfocused-foreground = ${colors.foreground-not-focus}
label-unfocused-padding = 2

; visible = Active workspace on unfocused monitor
label-visible = "Ó†∑"
label-visible-background = ${colors.background}
label-visible-foreground = ${colors.foreground-focus}
label-visible-underline = ${colors.background}
label-visible-padding = ${self.label-focused-padding}

; urgent = Workspace with urgency hint set
label-urgent = "Óü∑"
label-urgent-background = ${colors.background}
label-urgent-foreground = ${colors.alert}
label-urgent-padding = 2

[module/eth]
type = internal/network
interface = eno1
interval = 5.0

format-connected-underline = ${colors.background}
format-connected-prefix = "ÔõŅ "
format-connected-prefix-foreground = ${colors.foreground}
label-connected = %local_ip%
label-connected-foreground = ${colors.foreground}

format-disconnected =

[module/date]
type = internal/date
interval = 10

date = "Ó§Ė %a %e %b"
date-alt = "%d %m %Y"

time = "ÓÜí %H:%M"
time-alt = %H:%M

format-prefix-foreground = ${colors.foreground}
format-foreground = ${colors.foreground}
format-underline = ${colors.background}

label = %date% %time%

[module/alsa]
type = internal/alsa

format-volume = <ramp-volume> <bar-volume>

format-muted-prefix = "ÓĀŹ "
format-muted-foreground = ${colors.foreground-not-focus}
label-muted = muted
label-muted-font = 1

ramp-volume-0 = "ÓĀé"
ramp-volume-1 = "ÓĀć"
ramp-volume-2 = "ÓĀź"
ramp-volume-foreground = ${colors.foreground}

bar-volume-width = 10
bar-volume-foreground-0 = ${colors.foreground}
bar-volume-foreground-1 = ${colors.foreground}
bar-volume-foreground-2 = ${colors.foreground}
bar-volume-foreground-3 = ${colors.foreground}
bar-volume-foreground-4 = ${colors.foreground}
bar-volume-foreground-5 = ${colors.foreground}
bar-volume-foreground-6 = ${colors.foreground}
bar-volume-gradient = false
bar-volume-indicator = "ÓĀ°"
bar-volume-indicator-font = 2
bar-volume-indicator-foreground = ${colors.foreground-focus}
bar-volume-fill = "‚ĒÄ"
bar-volume-fill-font = 2
bar-volume-empty = "‚ĒÄ"
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-not-focus}

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false

[global/wm]
margin-top = 5
margin-bottom = 5

