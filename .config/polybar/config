[colors]
background = #282a36
background-alt = #21222c
background-shaded = #a282a36
foreground = #f8f8f2
foreground-alt = #f8f8f2
primary = #44475a
secondary = #6272a4
alert = #ff5555
cyan = #8be9fd
green = #50fa7b

[bar/topbar]
monitor = ${env:MONITOR:eDP1}
width = 100%
height = 25
offset-x = 0
offset-y = 0
radius = 0
fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 0

border-size = 0
border-bottom-size = 1
border-bottom-color = ${colors.background-alt}

padding-left = 5
padding-right = 5

module-margin-left = 2
module-margin-right = 2

font-0 = Monaco For Powerline:size=10;2
font-1 = Material Icons:style=Regular:size=10;2
font-2 = FontAwesome5Free:style=Solid:size=10;2
font-3 = FontAwesome5Free:style=Regular:size=10;2

modules-left = alsa
modules-center = i3
modules-right = wifi eth date battery

tray-position = none

[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /

label-mounted = %{F#0a81f5}%mountpoint%%{F-}: %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.foreground-alt}

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = false
enable-scroll = false
wrapping-scroll = false

; Only show workspaces on the same output as the bar
pin-workspaces = true

label-mode-padding = 2
label-mode-foreground = ${colors.primary}
label-mode-background = ${colors.background}

; focused = Active workspace on focused monitor
label-focused = "Ó†∑"
label-focused-background = ${colors.background-shaded}
label-focused-foreground = ${colors.foreground}
label-focused-underline= ${colors.foreground}
label-focused-padding = 2

; unfocused = Inactive workspace on any monitor
label-unfocused = "Ó†∂"
label-unfocused-foreground = ${colors.secondary}
label-unfocused-padding = 2

; visible = Active workspace on unfocused monitor
label-visible = "Ó†∑"
label-visible-background = ${colors.background-shaded}
label-visible-foreground = ${colors.foreground}
label-visible-underline = ${colors.primary}
label-visible-padding = ${self.label-focused-padding}

; urgent = Workspace with urgency hint set
label-urgent = "Óü∑"
label-urgent-background = ${colors.background-shaded}
label-urgent-foreground = ${colors.alert}
label-urgent-padding = 2

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "ÓÄ¶ "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = #f90000
label = %percentage:2%%

[module/memory]
type = internal/memory
interval = 2
format-prefix = "ÓÄ® "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = ${colors.cyan}
label = %percentage_used%%

[module/eth]
type = internal/network
interface = enp4s0f1
interval = 5.0

format-connected-underline = ${colors.green}
format-connected-prefix = "ÔõŅ "
format-connected-prefix-foreground = ${colors.foreground}
label-connected = %local_ip%
label-connected-foreground =  ${colors.foreground}

format-disconnected =

[module/wifi]
type = internal/network
interface = wlp3s0
interval = 5.0

format-connected-underline = ${colors.green}
format-connected-prefix = "Óėĺ "
format-connected-prefix-foreground = ${colors.foreground}
label-connected = %essid%:%local_ip%
label-connected-foreground = ${colors.foreground}

format-disconnected = "Óáö "

[module/date]
type = internal/date
interval = 10

date = "Ó§Ė %a %e %b"
date-alt = "%d %m %Y"

time = "ÓÜí %H:%M"
time-alt = %H:%M

format-prefix-foreground = ${colors.foreground}
format-foreground = ${colors.foreground}
format-underline = ${colors.foreground}

label = %date% %time%

[module/alsa]
type = internal/alsa

format-volume = <ramp-volume> <bar-volume>

format-muted-prefix = "ÓĀŹ "
format-muted-foreground = ${colors.primary}
label-muted = muted
label-muted-font = 1


ramp-volume-0 = "ÓĀé"
ramp-volume-1 = "ÓĀć"
ramp-volume-2 = "ÓĀź"
ramp-volume-foreground = ${colors.foreground}

bar-volume-width = 10
bar-volume-foreground-0 = ${colors.foreground}
bar-volume-foreground-1 = ${colors.foreground}
bar-volume-foreground-2 = ${colors.foreground}
bar-volume-foreground-3 = ${colors.foreground}
bar-volume-foreground-4 = ${colors.foreground}
bar-volume-foreground-5 = ${colors.foreground}
bar-volume-foreground-6 = ${colors.foreground}
bar-volume-gradient = false
bar-volume-indicator = "ÓĀ°"
bar-volume-indicator-font = 2
bar-volume-indicator-foreground = ${colors.foreground}
bar-volume-fill = "‚ĒÄ"
bar-volume-fill-font = 2
bar-volume-empty = "‚ĒÄ"
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground}

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 60

format = <ramp> <label>
format-underline = #f50a4d
format-warn = <ramp> <label-warn>
format-warn-underline = ${self.format-underline}

label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = ${colors.secondary}

ramp-0 = ÓÉČ
ramp-1 = ÓÉä
ramp-2 = ÓÉč
ramp-foreground = ${colors.foreground-alt}

[module/battery]
type = internal/battery

; This is useful in case the battery never reports 100% charge
full-at = 99

; Use the following command to list batteries and adapters:
; $ ls -1 /sys/class/power_supply/
battery = BAT1
adapter = ACAD

poll-interval = 5

time-format = %H:%M

label-discharging = %time%
format-discharging = <ramp-capacity> <label-discharging>
label-charging = "ÔÉß %time%"
format-charging = <ramp-capacity> <label-charging>
label-full = "ÔČÄ"
ramp-capacity-0 = ÔČĄ
ramp-capacity-1 = ÔČÉ
ramp-capacity-2 = ÔČā
ramp-capacity-3 = ÔČĀ
ramp-capacity-4 = ÔČÄ

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false

[global/wm]
margin-top = 5
margin-bottom = 5

